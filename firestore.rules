rules_version = '2';

// V4.8.8 rules: allow the family creator/owner to reconnect and repair their member record.
// This prevents lockout if the owner member document is missing or was not created correctly.

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isMember(familyId) {
      return signedIn()
        && exists(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid));
    }

    function isOwner(familyId) {
      return signedIn()
        && get(/databases/$(database)/documents/families/$(familyId)).data.createdBy == request.auth.uid;
    }

    match /users/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    match /families/{familyId} {
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid;

      // Members can read/update. The original creator can also read/update even if their member record is missing.
      allow read, update: if isMember(familyId)
        || (signedIn() && resource.data.createdBy == request.auth.uid);

      allow delete: if false;

      match /members/{uid} {
        allow read: if isMember(familyId)
          || isOwner(familyId)
          || (signedIn() && request.auth.uid == uid);

        // A user can create their own member record if they know the invite code.
        // The family owner can also create/repair their own member record.
        allow create: if signedIn()
          && request.auth.uid == uid
          && (
            isOwner(familyId)
            || request.resource.data.inviteCode == get(/databases/$(database)/documents/families/$(familyId)).data.inviteCode
          );

        // Users can update their own member record. Owner can also manage member docs.
        allow update: if (signedIn() && request.auth.uid == uid)
          || isOwner(familyId);

        allow delete: if isOwner(familyId);
      }

      match /state/{docId} {
        allow read, write: if isMember(familyId) || isOwner(familyId);
      }
    }
  }
}
