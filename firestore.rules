rules_version = '2';

// V4.8.20 rollback package keeps V4.8.15 owner-aware Firestore rules.
// Fixed owner emails:
// - fadlon1980@gmail.com
// - fadlonmay@gmail.com

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isFixedOwnerEmail() {
      return signedIn()
        && request.auth.token.email_verified == true
        && (
          request.auth.token.email == "fadlon1980@gmail.com"
          || request.auth.token.email == "fadlonmay@gmail.com"
        );
    }

    function memberDoc(familyId) {
      return get(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid));
    }

    function isMember(familyId) {
      return signedIn()
        && exists(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid));
    }

    function isOriginalCreator(familyId) {
      return signedIn()
        && get(/databases/$(database)/documents/families/$(familyId)).data.createdBy == request.auth.uid;
    }

    function isRoleOwnerOrAdmin(familyId) {
      return isMember(familyId)
        && (
          memberDoc(familyId).data.role == "owner"
          || memberDoc(familyId).data.role == "admin"
        );
    }

    function isFamilyManager(familyId) {
      return isOriginalCreator(familyId)
        || isFixedOwnerEmail()
        || isRoleOwnerOrAdmin(familyId);
    }

    match /users/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    match /families/{familyId} {
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid;

      allow read: if isMember(familyId) || isOriginalCreator(familyId) || isFixedOwnerEmail();
      allow update: if isMember(familyId) || isOriginalCreator(familyId) || isFixedOwnerEmail();
      allow delete: if false;

      match /members/{uid} {
        allow read: if isMember(familyId)
          || isOriginalCreator(familyId)
          || isFixedOwnerEmail()
          || (signedIn() && request.auth.uid == uid);

        allow create: if signedIn()
          && (
            isFamilyManager(familyId)
            || (
              request.auth.uid == uid
              && (
                isOriginalCreator(familyId)
                || isFixedOwnerEmail()
                || request.resource.data.inviteCode == get(/databases/$(database)/documents/families/$(familyId)).data.inviteCode
              )
            )
          );

        allow update: if isFamilyManager(familyId)
          || (
            signedIn()
            && request.auth.uid == uid
            && request.resource.data.role == resource.data.role
          );

        allow delete: if isFamilyManager(familyId);
      }

      match /state/{docId} {
        allow read, write: if isMember(familyId) || isOriginalCreator(familyId) || isFixedOwnerEmail();
      }
    }
  }
}
