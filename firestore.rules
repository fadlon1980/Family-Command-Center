rules_version = '2';

// V4.8.14 rules: original creator OR a member with role owner/admin can manage family.
// The app also hard-codes these emails as owner in the UI:
// fadlon1980@gmail.com and fadlonmay@gmail.com.
// Firestore rules cannot safely check email alone, so they use the member role stored in Firestore.

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function memberDoc(familyId) {
      return get(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid));
    }

    function isMember(familyId) {
      return signedIn()
        && exists(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid));
    }

    function isOriginalCreator(familyId) {
      return signedIn()
        && get(/databases/$(database)/documents/families/$(familyId)).data.createdBy == request.auth.uid;
    }

    function isFamilyManager(familyId) {
      return isOriginalCreator(familyId)
        || (
          isMember(familyId)
          && (
            memberDoc(familyId).data.role == "owner"
            || memberDoc(familyId).data.role == "admin"
          )
        );
    }

    match /users/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    match /families/{familyId} {
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid;

      allow read: if isMember(familyId) || isOriginalCreator(familyId);
      allow update: if isMember(familyId) || isOriginalCreator(familyId);
      allow delete: if false;

      match /members/{uid} {
        allow read: if isMember(familyId)
          || isOriginalCreator(familyId)
          || (signedIn() && request.auth.uid == uid);

        // Join/repair:
        // - original creator can repair/create their member record
        // - family manager can manage members
        // - user can create own member if they know invite code
        allow create: if signedIn()
          && (
            isFamilyManager(familyId)
            || (
              request.auth.uid == uid
              && (
                isOriginalCreator(familyId)
                || request.resource.data.inviteCode == get(/databases/$(database)/documents/families/$(familyId)).data.inviteCode
              )
            )
          );

        // User may update their own presence/profile fields.
        // Family manager may update roles and member records.
        allow update: if isFamilyManager(familyId)
          || (
            signedIn()
            && request.auth.uid == uid
            && request.resource.data.role == resource.data.role
          );

        allow delete: if isFamilyManager(familyId);
      }

      match /state/{docId} {
        allow read, write: if isMember(familyId) || isOriginalCreator(familyId);
      }
    }
  }
}
